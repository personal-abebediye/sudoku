#!/bin/bash

# Pre-push hook for running local CI checks
# This hook runs before pushing to ensure code quality

echo "🔍 Running pre-push checks..."
echo ""

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track overall success
CHECKS_PASSED=true

# 1. Validate YAML files
echo "📋 Validating YAML files..."
if command -v yamllint &> /dev/null; then
    if ! yamllint -d '{extends: default, rules: {line-length: disable, document-start: disable, truthy: disable, brackets: disable, trailing-spaces: disable, empty-lines: disable}}' .github/workflows/*.yml > /tmp/yamllint.log 2>&1; then
        echo -e "${RED}❌ YAML validation failed:${NC}"
        cat /tmp/yamllint.log
        CHECKS_PASSED=false
    fi
else
    echo -e "${YELLOW}⚠️  yamllint not installed, skipping YAML validation${NC}"
fi

if [ "$CHECKS_PASSED" = false ]; then
    echo ""
    echo -e "${RED}❌ Pre-push checks failed${NC}"
    exit 1
fi

# 2. Format check
echo "📝 Checking code formatting..."
if ! dart format --set-exit-if-changed . > /dev/null 2>&1; then
    echo -e "${YELLOW}⚠️  Code not formatted. Auto-formatting...${NC}"
    dart format .
    echo -e "${YELLOW}⚠️  Files were formatted. Please review changes and commit again.${NC}"
    CHECKS_PASSED=false
fi

if [ "$CHECKS_PASSED" = false ]; then
    echo ""
    echo -e "${RED}❌ Pre-push checks failed${NC}"
    exit 1
fi

# 3. Static analysis
echo "🔎 Running static analysis..."
if ! flutter analyze --no-fatal-infos > /tmp/analyze.log 2>&1; then
    echo -e "${RED}❌ Static analysis failed:${NC}"
    cat /tmp/analyze.log
    CHECKS_PASSED=false
fi

if [ "$CHECKS_PASSED" = false ]; then
    echo ""
    echo -e "${RED}❌ Pre-push checks failed${NC}"
    exit 1
fi

# 4. Run tests
echo "🧪 Running tests..."
if ! flutter test > /tmp/test.log 2>&1; then
    echo -e "${RED}❌ Tests failed:${NC}"
    cat /tmp/test.log
    CHECKS_PASSED=false
fi

# Final result
echo ""
if [ "$CHECKS_PASSED" = true ]; then
    echo -e "${GREEN}✅ All pre-push checks passed!${NC}"
    echo ""
    exit 0
else
    echo -e "${RED}❌ Pre-push checks failed${NC}"
    echo "Fix the issues above before pushing."
    echo ""
    exit 1
fi
